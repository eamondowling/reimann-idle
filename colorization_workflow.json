{
  "1": {
    "inputs": { "image": "REPLACE_WITH_FILENAME.png", "upload": "image" },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Sketch Image" }
  },
  "2": {
    "inputs": { "ckpt_name": "v1-5-pruned-emaonly-fp16.safetensors" },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load Checkpoint (SD 1.5)" }
  },
  "3": {
    "inputs": { "control_net_name": "control_v11p_sd15_lineart.pth" },
    "class_type": "ControlNetLoader",
    "_meta": { "title": "Load Lineart ControlNet" }
  },
  "4": {
    "inputs": { "control_net_name": "control_v11f1p_sd15_depth.pth" },
    "class_type": "ControlNetLoader",
    "_meta": { "title": "Load Depth ControlNet" }
  },
  "5": {
    "inputs": { "coarse": "disable", "resolution": 512, "image": ["1", 0] },
    "class_type": "LineartStandardPreprocessor",
    "_meta": { "title": "Lineart Preprocessor" }
  },
  "6": {
    "inputs": { "resolution": 512, "image": ["1", 0] },
    "class_type": "MiDaS-DepthMapPreprocessor",
    "_meta": { "title": "MiDaS Depth Preprocessor" }
  },
  "7": {
    "inputs": { "strength": 0.8, "start_percent": 0.0, "end_percent": 1.0, "positive": ["12", 0], "negative": ["13", 0], "control_net": ["3", 0], "image": ["5", 0] },
    "class_type": "ControlNetApplyAdvanced",
    "_meta": { "title": "Apply Lineart ControlNet" }
  },
  "8": {
    "inputs": { "strength": 0.5, "start_percent": 0.0, "end_percent": 0.8, "positive": ["7", 0], "negative": ["7", 1], "control_net": ["4", 0], "image": ["6", 0] },
    "class_type": "ControlNetApplyAdvanced",
    "_meta": { "title": "Apply Depth ControlNet" }
  },
  "9": {
    "inputs": { "pixels": ["1", 0], "vae": ["2", 2] },
    "class_type": "VAEEncode",
    "_meta": { "title": "VAE Encode" }
  },
  "10": {
    "inputs": { "seed": 888888888, "steps": 30, "cfg": 7.5, "sampler_name": "dpmpp_2m_sde", "scheduler": "karras", "denoise": 0.75, "model": ["2", 0], "positive": ["8", 0], "negative": ["8", 1], "latent_image": ["9", 0] },
    "class_type": "KSampler",
    "_meta": { "title": "KSampler (Colorize Pass)" }
  },
  "11": {
    "inputs": { "samples": ["10", 0], "vae": ["2", 2] },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" }
  },
  "12": {
    "inputs": { "text": "masterpiece, highly detailed colorized etching, harmonious palette of deep cosmic blues, rich indigos, warm golden accents, and soft pearlescent ivory tones, antique parchment texture finish, mystical atmosphere", "clip": ["2", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive Prompt" }
  },
  "13": {
    "inputs": { "text": "monochrome, black and white, grayscale, neon colors, oversaturated, low quality, deformed, mutated, text, signatures", "clip": ["2", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative Prompt" }
  },
  "14": {
    "inputs": { "filename_prefix": "Colorized_REPLACE", "images": ["11", 0] },
    "class_type": "SaveImage",
    "_meta": { "title": "Save Colorized Output" }
  }
}
